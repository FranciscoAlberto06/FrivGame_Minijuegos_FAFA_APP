<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrivGame_Minijuegos_FAFA_APP.BuscarParejas"
             Title="BuscarParejas">

    <VerticalStackLayout Padding="20" Spacing="30" VerticalOptions="Center">

        <Label x:Name="LblEstado" 
               Text="¡Encuentra las parejas!" 
               FontSize="28" 
               HorizontalOptions="Center" 
               FontAttributes="Bold" 
               TextColor="Purple"/>

        <Grid x:Name="GridTablero" 
              ColumnSpacing="15" 
              RowSpacing="15" 
              HorizontalOptions="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="110"/>
                <RowDefinition Height="110"/>
                <RowDefinition Height="110"/>
                <RowDefinition Height="110"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
        </Grid>

        <Button Text="Reiniciar Juego" 
                x:Name="bReiniciar"
                Clicked="ReiniciarJuego" 
                BackgroundColor="Purple"
                IsVisible="False"
                FontSize="18"
                HeightRequest="50"
                WidthRequest="200"
                HorizontalOptions="Center"/>

    </VerticalStackLayout>

</ContentPage>