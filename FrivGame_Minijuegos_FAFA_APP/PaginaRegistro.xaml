<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrivGame_Minijuegos_FAFA_APP.PaginaRegistro"
             Title="PaginaRegistro"
             Shell.NavBarIsVisible="False">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1E293B" Offset="0.0" />
                <GradientStop Color="#0F172A" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout 
                Spacing="20"
                Padding="30"
                WidthRequest="350">

                <Label 
                    Text="Crea tu Perfil"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalOptions="Center"/>

                <Label 
                    Text="Únete a la comunidad de AbelGame"
                    FontSize="14"
                    TextColor="#94A3B8"
                    HorizontalOptions="Center"
                    Margin="0,0,0,10"/>

                <Border 
                    StrokeThickness="0"
                    BackgroundColor="#1E293B"
                    Padding="25"
                    StrokeShape="RoundRectangle 25">

                    <VerticalStackLayout Spacing="15">

                        <Entry 
                            x:Name="eNombreUsuario"
                            Placeholder="Nombre de usuario"
                            TextColor="White"
                            PlaceholderColor="#64748B"
                            BackgroundColor="#0F172A"
                            HeightRequest="50"/>

                        <Entry 
                            x:Name="eEmail"
                            Placeholder="Correo electrónico"
                            Keyboard="Email"
                            TextColor="White"
                            PlaceholderColor="#64748B"
                            BackgroundColor="#0F172A"
                            HeightRequest="50"/>

                        <Entry 
                            x:Name="ePassword"
                            Placeholder="Contraseña"
                            IsPassword="True"
                            TextColor="White"
                            PlaceholderColor="#64748B"
                            BackgroundColor="#0F172A"
                            HeightRequest="50"/>

                        <Label 
                            Text="Elige tu avatar"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalOptions="Center"/>

                        <CollectionView x:Name="listaAvatares"
                                        HeightRequest="110"
                                        SelectionMode="Single"
                                        SelectionChanged="OnAvatarSeleccionado"
                                        HorizontalOptions="Center"
                                        HorizontalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="3"
                                            Padding="2"
                                            StrokeShape="RoundRectangle 40">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                    <VisualState x:Name="Selected">
                                                        <VisualState.Setters>
                                                            <Setter Property="Stroke" Value="#10B981"/>
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>
                                        <Image Source="{Binding}"
                                               HeightRequest="80"
                                               WidthRequest="80"
                                               Aspect="AspectFill"/>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label 
                             x:Name="lError"
                             Text=""
                             TextColor="Red" 
                             FontSize="13"
                             HorizontalOptions="Center"
                             IsVisible="False"
                             Margin="0,5,0,0"/>

                        <Button 
                            Text="Registrarse ahora"
                            HeightRequest="50"
                            CornerRadius="15"
                            BackgroundColor="#10B981" 
                            TextColor="White"
                            FontAttributes="Bold"
                            Margin="0,10,0,0"
                            Clicked="clickRegistrar"/>

                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout 
                    HorizontalOptions="Center"
                    Spacing="5">
                    <Label Text="¿Ya tienes cuenta?" TextColor="#94A3B8"/>
                    <Label Text="Inicia sesión" TextColor="#6366F1" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="VolverAlInicio"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>