<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrivGame_Minijuegos_FAFA_APP._2048game"
             Title="_2048game"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">
    
    
<VerticalStackLayout Spacing="15" Padding="20" HorizontalOptions="Center" VerticalOptions="Center">

        <Label Text="2048" 
               FontSize="56" 
               FontAttributes="Bold" 
               TextColor="#7289DA" 
               HorizontalOptions="Center"/>

        <Label x:Name="lPuntuacion" 
               Text="Puntos: 0" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="#7289DA" 
               HorizontalOptions="Center"/>

        <Border BackgroundColor="#2C2F33" 
                Padding="10" 
                StrokeThickness="0"
                MaximumWidthRequest="360">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>

            <Grid x:Name="tableroGrid" 
                  RowDefinitions="*,*,*,*" 
                  ColumnDefinitions="*,*,*,*" 
                  RowSpacing="10" 
                  ColumnSpacing="10"
                  HeightRequest="300"
                  WidthRequest="300">

                <Grid.GestureRecognizers>
                    <SwipeGestureRecognizer Direction="Up" Swiped="onDeslizamiento"/>
                    <SwipeGestureRecognizer Direction="Down" Swiped="onDeslizamiento"/>
                    <SwipeGestureRecognizer Direction="Left" Swiped="onDeslizamiento"/>
                    <SwipeGestureRecognizer Direction="Right" Swiped="onDeslizamiento"/>
                </Grid.GestureRecognizers>
            </Grid>
        </Border>

        <Button Text="NUEVO JUEGO" 
                Clicked="ResetJuego" 
                BackgroundColor="#7289DA" 
                TextColor="White" 
                CornerRadius="20" 
                HeightRequest="50"
                FontAttributes="Bold" 
                Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>