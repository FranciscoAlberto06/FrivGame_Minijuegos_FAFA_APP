<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrivGame_Minijuegos_FAFA_APP.AdivinaPalabra"
             Title="AdivinaPalabra">
    
    <VerticalStackLayout 
    Padding="30"
    Spacing="25"
    VerticalOptions="Center">

        <Label 
        Text="Adivina la Palabra"
        FontSize="28"
        HorizontalOptions="Center"/>

        <Label 
        x:Name="PalabraLabel"
        Text="_ _ _ _"
        FontSize="32"
        HorizontalOptions="Center"/>

        <Entry 
        x:Name="LetraEntry"
        Placeholder="Introduce una letra"
        MaxLength="1"
        HorizontalOptions="Center"/>

        <Button 
        Text="Probar letra"
        Clicked="OnProbarLetraClicked"/>

        <Label 
        x:Name="IntentosLabel"
        Text="Intentos restantes: 6"
        HorizontalOptions="Center"/>

        <Button 
        Text="Reiniciar"
        Clicked="OnReiniciarClicked"/>

    </VerticalStackLayout>
    
</ContentPage>